# Python cache
__pycache__/
*.py[cod]

# Local secrets and environment
.env
*.env

# Runtime data generated by the collector
data/raw/**
data/ohlcv/**
data/indicators/**
data/state/**
data/logs/**
!data/raw/.gitkeep
!data/ohlcv/.gitkeep
!data/indicators/.gitkeep
!data/state/.gitkeep
!data/logs/.gitkeep
