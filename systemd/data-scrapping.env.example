# Copy to /etc/data-scrapping.env and chmod 600.
# Keep this file out of git if you add real keys.
TWELVE_DATA_API_KEY=replace-me
FRED_API_KEY=replace-me
FINNHUB_API_KEY=replace-me
ALPHA_VANTAGE_API_KEY=replace-me
DISCORD_WEBHOOK_URL=

# Conservative per-run batch sizes.
TWELVE_MAX_SYMBOLS=700
FRED_LIMIT=2
FINNHUB_LIMIT=2
FINNHUB_DAYS_BACK=7
ALPHA_VANTAGE_MAX_SYMBOLS=2

# Toggle individual stages.
RUN_FETCH_TICKERS=0
RUN_TWELVE=1
RUN_ALPHA_VANTAGE=0
RUN_INDICATORS=1
RUN_FRED=1
RUN_FINNHUB=1
RUN_SUMMARY=1
RUN_DUCKDB_VALIDATE=1
SEND_DISCORD=0

# Set to 1 to verify orchestration without API calls.
DRY_RUN=0
PYTHON_BIN=python

# Optional rclone backup settings.
RCLONE_DEST=remote:data-scrapping
RCLONE_DRY_RUN=0
BACKUP_MODE=copy
BACKUP_DATA_DIR=data
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=8
